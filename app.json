{
  "expo": {
    "name": "Gidana",
    "slug": "gidana",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/android-chrome-512x512.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/android-chrome-192x192.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gidana.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-chrome-512x512.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.gidana.app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Gidana uses your location to show properties near you.",
          "locationWhenInUsePermission": "Gidana uses your location to show properties near you."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/android-chrome-512x512.png",
          "color": "#0d5c03",
          "defaultChannel": "messages"
        }
      ],
      "expo-localization"
    ],
    "newArchEnabled": true,
    "extra": {
      "eas": {
        "projectId": "3c550835-c0c3-4955-a5c1-9f683337db84"
      }
    }
  }
}
